#!/bin/sh

set -eu

mkdir -p /etc/pgbouncer

# Build pgbouncer.ini from environment variables
cat > /etc/pgbouncer/pgbouncer.ini << EOF
[databases]
${POSTGRES_DB} = host=${PGBOUNCER_BACKEND_HOST:-postgres} port=${POSTGRES_PORT:-5432} dbname=${POSTGRES_DB}

[pgbouncer]
listen_addr = 0.0.0.0
listen_port = ${PGBOUNCER_LISTEN_PORT:-6432}
auth_type = md5
auth_file = /etc/pgbouncer/userlist.txt

; Connection pooling mode: transaction pooling is recommended for Django
; with ATOMIC_REQUESTS=True as each request maps to one transaction.
pool_mode = ${PGBOUNCER_POOL_MODE:-transaction}

; Client connection limits
max_client_conn = ${PGBOUNCER_MAX_CLIENT_CONN:-200}

; Server connection pool size per database/user pair
default_pool_size = ${PGBOUNCER_DEFAULT_POOL_SIZE:-20}
min_pool_size = ${PGBOUNCER_MIN_POOL_SIZE:-5}
reserve_pool_size = ${PGBOUNCER_RESERVE_POOL_SIZE:-5}
reserve_pool_timeout = ${PGBOUNCER_RESERVE_POOL_TIMEOUT:-3}

; Timeouts
server_idle_timeout = ${PGBOUNCER_SERVER_IDLE_TIMEOUT:-600}
client_idle_timeout = ${PGBOUNCER_CLIENT_IDLE_TIMEOUT:-0}
server_connect_timeout = ${PGBOUNCER_SERVER_CONNECT_TIMEOUT:-15}
server_login_retry = ${PGBOUNCER_SERVER_LOGIN_RETRY:-15}

; For transaction pooling Django uses ATOMIC_REQUESTS so each HTTP request
; is exactly one PostgreSQL transaction.  We reset only the minimal session
; state that Django sets at connection time (timezone) so that a recycled
; backend connection always starts in a known, consistent state.
; Using DISCARD ALL would be correct but expensive; a lightweight SET is enough.
server_reset_query = SET TIME ZONE 'UTC'
server_reset_query_always = 0

; Verify that a backend connection is alive before assigning it to a client.
server_check_query = SELECT 1
server_check_delay = ${PGBOUNCER_SERVER_CHECK_DELAY:-30}

; Ignore parameters sent by psycopg/Django that PgBouncer does not understand
; as startup parameters.  application_name is handled natively by PgBouncer.
ignore_startup_parameters = extra_float_digits

; Logging
log_connections = 0
log_disconnections = 0
log_pooler_errors = 1

; Stats
stats_period = 60
EOF

# Write userlist.txt with the PostgreSQL credentials.
# PgBouncer uses these to authenticate both clients and the backend.
printf '"%s" "%s"\n' "${POSTGRES_USER}" "${POSTGRES_PASSWORD}" > /etc/pgbouncer/userlist.txt
chmod 0600 /etc/pgbouncer/userlist.txt

echo "PgBouncer is starting..."

exec pgbouncer /etc/pgbouncer/pgbouncer.ini
